# Frontend → Backend base URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Default similarity threshold (set as 0..1 or percent)
# Recommended starting point (from backend/evaluate.py --sweep on sample pairs): 0.58
NEXT_PUBLIC_DEFAULT_THRESHOLD=0.58

# CSV bulk upload chunk size
NEXT_PUBLIC_BULK_CHUNK_SIZE=200

# Backend config (set these in your shell / deployment environment)
# MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
# DUPLICATE_THRESHOLD=0.70
