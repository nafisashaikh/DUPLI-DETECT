# DupliDetect Backend Configuration
# Copy this file to .env and adjust values as needed

# ===== BRAIN 1: SEMANTIC (Sentence-Transformers) =====
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
# Semantic similarity threshold (0–1) used as fallback in add-record checks.
DUPLICATE_THRESHOLD=0.70

# ===== BRAIN 2: PHONETIC (Epitran + fasttext_langdetect) =====
# No configuration needed; models auto-download on first use.
# Ensure epitran language models are cached (see EPITRAN_DOWNLOAD.sh).

# ===== BRAIN 3: CONCEPTUAL (Static Knowledge Map) =====
CONCEPT_MAP_PATH=backend/concept_map.json
# Path to concept_map.json. Defaults to backend/ if not set.

# ===== NEW /compare ENDPOINT DEFAULTS =====
# Weights for multi-brain scoring (will be normalized automatically).
W_SEM=0.4
W_PHO=0.3
W_CON=0.3

# Default threshold for final duplicate verdict (0–1).
THRESHOLD=0.75

# ===== ADVANCED CONFIGURATION =====
# Individual brain weights for add-record and search (optional; overridden by per-request weights).
SEMANTIC_WEIGHT=0.60
PHONETIC_WEIGHT=0.20
CONCEPT_WEIGHT=0.20

# Comparison-specific threshold (can differ from DUPLICATE_THRESHOLD).
COMPARE_THRESHOLD=0.75

# Thresholds for duplicate type classification.
TYPO_RATIO_THRESHOLD=0.92
LANGUAGE_DIFFERENCE_THRESHOLD=0.70

# ===== DATABASE =====
# Use SQLite as persistent local storage (default: true).
USE_SQLITE=true
SQLITE_PATH=backend/duplidetect.sqlite

# Optional: Firebase Credentials for cloud sync (if omitted, uses SQLite fallback).
FIREBASE_CREDENTIALS=firebase-credentials.json

# ===== API & EXTERNAL SERVICES =====
# NVIDIA API key for PDF OCR (optional; if absent, uses mock data for testing).
NVIDIA_API_KEY=

# ===== FRONTEND =====
# Backend API URL (used by React frontend).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Default similarity threshold for frontend display
NEXT_PUBLIC_DEFAULT_THRESHOLD=0.75

# CSV bulk upload chunk size
NEXT_PUBLIC_BULK_CHUNK_SIZE=200
